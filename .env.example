# Claude Terminal Configuration
# Copy this file to .env and customize

# ──────────────────────────────────────
# Authentication
# ──────────────────────────────────────
# Set your password (required on first run)
# The server will hash it automatically and store the hash
PASSWORD=changeme

# Session lifetime in seconds (default: 24 hours)
SESSION_MAX_AGE=86400

# Rate limiting: max failed login attempts per IP within window
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=900

# ──────────────────────────────────────
# Server
# ──────────────────────────────────────
HOST=0.0.0.0
PORT=7682

# Domain for display purposes (optional)
# If set, shown in README setup output
DOMAIN=

# ──────────────────────────────────────
# Paths
# ──────────────────────────────────────
# ttyd port (web terminal)
TTYD_PORT=7681

# tmux socket path (auto-detected if empty)
TMUX_SOCKET=

# Directory for file uploads
UPLOAD_DIR=/tmp/claude-uploads

# Directory for notifications
NOTIFY_DIR=/tmp/claude-notify

# Git repository to show in dashboard (optional)
GIT_DIR=

# ──────────────────────────────────────
# Brain (Claude Code memory/skills/agents)
# ──────────────────────────────────────
# Comma-separated list of project directories to scan
# Each dir should contain a .claude/ subdirectory
# Leave empty to only scan global ~/.claude/
PROJECT_DIRS=

# ──────────────────────────────────────
# Claude Code
# ──────────────────────────────────────
# tmux session name for Claude Code
TMUX_SESSION=claude

# Claude startup command
CLAUDE_CMD=claude --dangerously-skip-permissions
